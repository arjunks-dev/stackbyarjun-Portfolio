# Site URL (used for SEO, sitemap, OpenGraph)
NEXT_PUBLIC_SITE_URL=https://stackbyarjun.com

# Cloudflare Web Analytics (OPTIONAL — see DEPLOYMENT.md)
# Only needed for manual JS snippet setup (non-proxied sites).
# For Cloudflare Pages: enable Web Analytics in Pages → Metrics (one-click, no token).
# For proxied custom domains: enable automatic injection in Web Analytics dashboard (no token).
# NEXT_PUBLIC_CF_BEACON_TOKEN=

# Cloudflare Turnstile (contact form)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your-turnstile-site-key
TURNSTILE_SECRET_KEY=your-turnstile-secret-key

# Contact form API (optional - use with your preferred email service)
CONTACT_FORM_WEBHOOK_URL=

# GitHub username for contribution widget
NEXT_PUBLIC_GITHUB_USERNAME=stackbyarjun

# Decap CMS (configured in public/admin/config.yml)
# GitHub OAuth App credentials for /admin authentication
# Set these in Cloudflare Pages / Vercel environment variables
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
